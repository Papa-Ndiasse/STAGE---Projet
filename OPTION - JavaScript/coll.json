        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Un email déjà utilisé renvoie une erreur 422 bien formée\", function () {\r",
              "    pm.response.to.have.status(422);  // exige précisément 422, pas un if\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData[0]).to.have.property(\"field\", \"email\");\r",
              "    pm.expect(jsonData[0]).to.have.property(\"message\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
