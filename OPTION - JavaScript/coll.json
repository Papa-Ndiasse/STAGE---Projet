  "item": [
    {
      "name": "POST",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const timer = Date.now() ; \r",
              "pm.environment.set(\"Email\", `xedonplasma${timer}@gmail.com`) ; "
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Le statut de la réponse est 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Le nom de l'utilisateur est Papa Ndiassé\", function()\r",
              "{\r",
              "    pm.expect(pm.response.json().name).to.eql(\"Papa Ndiassé\")\r",
              "})\r",
              "\r",
              "pm.test(\"le genre de l'utilisateur est \\\"male\\\"\", function()\r",
              "{\r",
              "    pm.expect(pm.response.json().gender).to.eql(\"male\")\r",
              "})\r",
              "\r",
              "pm.test(\"L'utilisateur est censé etre \\\"active\\\"\", function()\r",
              "{\r",
              "    pm.expect(pm.response.json().status).to.eql(\"active\")\r",
              "})\r",
              "\r",
              "pm.test(\"L'id à bien été crée et est un nombre\", function()\r",
              "{\r",
              "    pm.expect(pm.response.json().id).to.be.a(\"number\")\r",
              "})\r",
              "\r",
              "const JsonD = pm.response.json() ; \r",
              "pm.environment.set(\"UserId\", JsonD.id) ; \r",
              "\r",
              "\r",
              "const schéma = \r",
              "{\r",
              "    type : \"object\", // la réponse doit etre en JSON\r",
              "    required : [\"id\", \"name\", \"email\", \"gender\", \"status\"],\r",
              "    properties:\r",
              "    {\r",
              "        id: {type : \"number\"},\r",
              "        name: {type : \"string\"},\r",
              "        email: {type : \"string\"}, \r",
              "        gender: {type : \"string\"},\r",
              "        status: {type : \"string\"}\r",
              "    }\r",
              "    \r",
              "} ; \r",
              "\r",
              "pm.test(\"Le résultat respecte le schéma\", function()\r",
              "{\r",
              "    pm.response.to.have.jsonSchema(schéma)\r",
              "})\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\" : \"Papa Ndiassé\",\r\n    \"email\" : \"{{Email}}\",\r\n    \"gender\" : \"male\",\r\n    \"status\" : \"active\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{URL}}public/v2/users/",
          "host": [
            "{{URL}}public"
          ],
          "path": [
            "v2",
            "users",
            ""
          ]
        }
      },
      "response": []
